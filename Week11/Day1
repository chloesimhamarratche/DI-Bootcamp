function limitLoginAttempts(req, res, next) {
  const ip = req.ip
  const now = Date.now()

  if (!loginAttempts[ip]) {
    loginAttempts[ip] = {
      count: 1,
      firstAttempt: now
    }

    return next()
  }

  const timePassed = now - loginAttempts[ip].firstAttempt

  if (timePassed > 15 * 60 * 1000) {
    loginAttempts[ip] = {
      count: 1,
      firstAttempt: now
    }

    return next()
  }

  if (loginAttempts[ip].count >= 5) {
    return res.status(429).json({
      message: "Too many login attempts. Try again later"
    })
  }

  loginAttempts[ip].count++
  next()
}

