<!DOCTYPE html>
<html>
<head>
  <title>Star Wars</title>

  <!-- Fontawesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">

  <style>
    body {
      background: black;
      color: yellow;
      text-align: center;
      font-family: Arial;
    }

    #box {
      border: 2px solid yellow;
      width: 300px;
      margin: 50px auto;
      padding: 20px;
    }

    button {
      margin-top: 20px;
      padding: 10px;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <h1>STAR WARS</h1>

  <div id="box">
    <p id="content">Click to find someone</p>
  </div>

  <button id="btn">Find Someone</button>

  <script>
    const btn = document.getElementById("btn");
    const content = document.getElementById("content");

    btn.addEventListener("click", async function() {
      content.innerHTML = '<i class="fas fa-spinner fa-spin"></i><br>Loading...';

      const randomId = Math.floor(Math.random() * 83) + 1;

      try {
        const response = await fetch(`https://www.swapi.tech/api/people/${randomId}`);

        if (!response.ok) {
          throw new Error("error");
        }

        const data = await response.json();
        const character = data.result.properties;

        // get homeworld
        const homeworldRes = await fetch(character.homeworld);
        const homeworldData = await homeworldRes.json();

        content.innerHTML = `
          <h3>${character.name}</h3>
          <p>Height: ${character.height}</p>
          <p>Gender: ${character.gender}</p>
          <p>Birth Year: ${character.birth_year}</p>
          <p>Home World: ${homeworldData.result.properties.name}</p>
        `;

      } catch (error) {
        content.innerHTML = "Oh No! That person isnt available.";
      }
    });
  </script>

</body>
</html>
