// EX6 

type Person2 = {
  name: string;
  age: number;
};

type Job = {
  position: string;
  department: string;
};

type Employee = Person2 & Job;

function describeEmployee(emp: Employee): string {
  if (emp.position === "Manager") {
    return emp.name + " is a Manager";
  } else {
    return emp.name + " is a Developer";
  }
}



