// EX8
function getAction(role: string): string {
  switch (role) {
    case "admin":
      return "Manage users and settings";
    case "editor":
      return "Edit content";
    case "viewer":
      return "View content";
    case "guest":
      return "Limited access";
    default:
      return "Invalid role";
  }
}


// EX9
function greet(name?: string): string {
  if (name) {
    return `Hello, ${name}`;
  } else {
    return "Hello, guest";
  }
}
