// EX7

let allBooks = [
{
title: "Harry Potter",
author: "J.K Rowling",
image: "https://m.media-amazon.com/images/I/51UoqRAxwEL.jpg",
alreadyRead: true
},
{
title: "The Alchemist",
author: "Paulo Coelho",
image: "https://m.media-amazon.com/images/I/71aFt4+OTOL.jpg",
alreadyRead: false
}
]

let section = document.querySelector(".listBooks")

for (let i = 0; i < allBooks.length; i++) {

let bookDiv = document.createElement("div")

let details = document.createElement("p")

details.innerText = allBooks[i].title + " written by " + allBooks[i].author

if (allBooks[i].alreadyRead === true){
details.style.color = "red"
}

let img = document.createElement("img")

img.src = allBooks[i].image
img.style.width = "100px"

bookDiv.appendChild(details)
bookDiv.appendChild(img)

section.appendChild(bookDiv)

}
