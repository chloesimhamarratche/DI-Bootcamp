// EX1
import { configureStore } from "@reduxjs/toolkit";
import booksReducer from "./booksSlice";

export const store = configureStore({
  reducer: {
    books: booksReducer
  }
});

export type RootState = ReturnType<typeof store.getState>;

// EX2
import { createSlice } from "@reduxjs/toolkit";

type Book = {
  id: number;
  title: string;
  author: string;
  genre: string;
};

type BooksState = {
  list: Book[];
};

const initialState: BooksState = {
  list: [
    { id: 1, title: "Harry Potter", author: "J.K Rowling", genre: "fantasy" },
    { id: 2, title: "It", author: "Stephen King", genre: "horror" },
    { id: 3, title: "Dune", author: "Frank Herbert", genre: "science" }
  ]
};

const booksSlice = createSlice({
  name: "books",
  initialState,
  reducers: {}
});

export default booksSlice.reducer;

// EX3
import { createSelector } from "@reduxjs/toolkit";
import { RootState } from "./store";

export const selectBooks = (state: RootState) => state.books.list;

export const selectFantasyBooks = createSelector(
  [selectBooks],
  books => books.filter(b => b.genre === "fantasy")
);

export const selectHorrorBooks = createSelector(
  [selectBooks],
  books => books.filter(b => b.genre === "horror")
);

export const selectScienceBooks = createSelector(
  [selectBooks],
  books => books.filter(b => b.genre === "science")
);

// EX4
import { useState } from "react";
import { useSelector } from "react-redux";
import {
  selectBooks,
  selectFantasyBooks,
  selectHorrorBooks,
  selectScienceBooks
} from "./selectors";

export const BookList = () => {
  const [genre, setGenre] = useState("all");

  const all = useSelector(selectBooks);
  const fantasy = useSelector(selectFantasyBooks);
  const horror = useSelector(selectHorrorBooks);
  const science = useSelector(selectScienceBooks);

  let data = all;
  if (genre === "fantasy") data = fantasy;
  if (genre === "horror") data = horror;
  if (genre === "science") data = science;

  return (
    <div>
      <h2>Books</h2>

      <button onClick={() => setGenre("all")}>All</button>
      <button onClick={() => setGenre("fantasy")}>Fantasy</button>
      <button onClick={() => setGenre("horror")}>Horror</button>
      <button onClick={() => setGenre("science")}>Science</button>

      <ul>
        {data.map(b => (
          <li key={b.id}>
            {b.title} - {b.author} ({b.genre})
          </li>
        ))}
      </ul>
    </div>
  );
};

// APP
import React from "react";
import { Provider } from "react-redux";
import { store } from "./store";
import { BookList } from "./BookList";

export default function App() {
  return (
    <Provider store={store}>
      <BookList />
    </Provider>
  );
}
