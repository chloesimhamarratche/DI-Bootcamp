// EX1
import { configureStore } from "@reduxjs/toolkit";
import tasksReducer from "./tasksSlice";
import categoriesReducer from "./categoriesSlice";

export const store = configureStore({
  reducer: {
    tasks: tasksReducer,
    categories: categoriesReducer
  }
});

export type RootState = ReturnType<typeof store.getState>;

// EX2
import { createSlice, PayloadAction } from "@reduxjs/toolkit";

type Task = {
  id: number;
  title: string;
  completed: boolean;
  categoryId: number;
};

type TasksState = {
  list: Task[];
};

const initialState: TasksState = {
  list: []
};

const tasksSlice = createSlice({
  name: "tasks",
  initialState,
  reducers: {
    addTask: (state, action: PayloadAction<Task>) => {
      state.list.push(action.payload);
    },
    toggleTask: (state, action: PayloadAction<number>) => {
      const t = state.list.find(x => x.id === action.payload);
      if (t) t.completed = !t.completed;
    },
    deleteTask: (state, action: PayloadAction<number>) => {
      state.list = state.list.filter(t => t.id !== action.payload);
    },
    editTask: (state, action: PayloadAction<Task>) => {
      const index = state.list.findIndex(t => t.id === action.payload.id);
      if (index !== -1) state.list[index] = action.payload;
    }
  }
});

export const { addTask, toggleTask, deleteTask, editTask } = tasksSlice.actions;
export default tasksSlice.reducer;

// EX3
import { createSlice, PayloadAction } from "@reduxjs/toolkit";

type Category = {
  id: number;
  name: string;
};

type CategoriesState = {
  list: Category[];
};

const initialStateCat: CategoriesState = {
  list: [
    { id: 1, name: "Work" },
    { id: 2, name: "Personal" }
  ]
};

const categoriesSlice = createSlice({
  name: "categories",
  initialState: initialStateCat,
  reducers: {
    addCategory: (state, action: PayloadAction<Category>) => {
      state.list.push(action.payload);
    }
  }
});

export const { addCategory } = categoriesSlice.actions;
export default categoriesSlice.reducer;

// EX4
import { createSelector } from "@reduxjs/toolkit";
import { RootState } from "./store";

export const selectTasks = (state: RootState) => state.tasks.list;
export const selectCategories = (state: RootState) => state.categories.list;

export const selectTasksByCategory = (categoryId: number) =>
  createSelector([selectTasks], tasks =>
    tasks.filter(t => t.categoryId === categoryId)
  );

export const selectCompletedTasks = createSelector(
  [selectTasks],
  tasks => tasks.filter(t => t.completed).length
);

export const selectCategoryById = (id: number) =>
  createSelector([selectCategories], cats =>
    cats.find(c => c.id === id)
  );

// EX5
import { useSelector } from "react-redux";
import { useState } from "react";
import { selectCategories } from "./selectors";

export const CategorySelector = ({ setCategory }: any) => {
  const categories = useSelector(selectCategories);

  return (
    <div>
      {categories.map(c => (
        <button key={c.id} onClick={() => setCategory(c.id)}>
          {c.name}
        </button>
      ))}
    </div>
  );
};

// EX6
import { useDispatch, useSelector } from "react-redux";
import { addTask, toggleTask, deleteTask } from "./tasksSlice";
import { useState } from "react";
import { selectTasksByCategory } from "./selectors";

export const TaskList = ({ categoryId }: any) => {
  const tasks = useSelector(selectTasksByCategory(categoryId));
  const dispatch = useDispatch();
  const [text, setText] = useState("");

  const add = () => {
    dispatch(
      addTask({
        id: Date.now(),
        title: text,
        completed: false,
        categoryId
      })
    );
    setText("");
  };

  return (
    <div>
      <input value={text} onChange={e => setText(e.target.value)} />
      <button onClick={add}>Add</button>

      <ul>
        {tasks.map((t: any) => (
          <li key={t.id}>
            <span onClick={() => dispatch(toggleTask(t.id))}>
              {t.title} {t.completed ? "✅" : ""}
            </span>
            <button onClick={() => dispatch(deleteTask(t.id))}>X</button>
          </li>
        ))}
      </ul>
    </div>
  );
};

// APP
import React, { useState } from "react";
import { Provider } from "react-redux";
import { store } from "./store";
import { TaskList } from "./TaskList";
import { CategorySelector } from "./CategorySelector";

export default function App() {
  const [category, setCategory] = useState(1);

  return (
    <Provider store={store}>
      <CategorySelector setCategory={setCategory} />
      <TaskList categoryId={category} />
    </Provider>
  );
}
