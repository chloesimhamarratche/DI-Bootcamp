from langchain_core.messages.ai import AIMessage

def human_node(state: OrderState) -> OrderState:
    last = state["messages"][-1]
    print(last.content)
    user = input("User: ")
    if user in ["q","quit","exit"]:
        state["finished"] = True
    return state | {"messages": [("user", user)]}

