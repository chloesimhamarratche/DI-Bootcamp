import os
from typing import Annotated, List, Literal
from typing_extensions import TypedDict
from langgraph.graph.message import add_messages

class OrderState(TypedDict):
    messages: Annotated[List, add_messages]
    order: List[str]
    finished: bool

BARISTABOT_SYSINT = (
"system",
"You are a BaristaBot. Help user order drinks from menu and confirm before placing order."
)

WELCOME_MSG = "Welcome to BaristaBot. What would you like to order?"

--EX3--
from langchain_google_genai import ChatGoogleGenerativeAI
from langchain_core.messages import AIMessage

llm = ChatGoogleGenerativeAI(model="gemini-2.5-flash-latest")

def chatbot(state: OrderState) -> OrderState:
    if state["messages"]:
        response = llm.invoke([BARISTABOT_SYSINT] + state["messages"])
    else:
        response = AIMessage(content=WELCOME_MSG)
    return {"messages": [response]}

